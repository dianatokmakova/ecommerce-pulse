# Скопируй в .env и поменяй значения. РЕАЛЬНЫЙ .env НИКОГДА не коммить (он в .gitignore).

# --- ClickHouse ---
CLICKHOUSE_USER=analyst
CLICKHOUSE_PASSWORD=change_me_strong_password

# --- MinIO (S3-озеро) ---
MINIO_ROOT_USER=ecp_minio
MINIO_ROOT_PASSWORD=change_me_strong_password

# --- Airflow UI ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_strong_password

# --- Источник цен (твой Fake API на Vercel) ---
FAKE_API_URL=https://ecommerce-pulse-api.vercel.app/api/prices

# --- OLTP Postgres (операционная БД маркетплейса, источник для ELT) ---
OLTP_PASSWORD=change_me_strong_password

# --- Dashboard API (read-only слой для фронта на Vercel) ---
# Пароль ДОЛЖЕН совпадать с bi_reader в infra/clickhouse/init/01_databases.sql
BI_READER_PASSWORD=change_me_bi_password
# Домен фронта на Vercel (CORS). Для демо можно оставить *
FRONTEND_ORIGIN=https://ecommerce-pulse.vercel.app

# --- (опц.) домен для HTTPS через Caddy ---
PUBLIC_DOMAIN=ch.example.com
